    // ── Core: Test ───────────────────────────────────────────────────────────────
    {
      "label": "core: test (run once)",
      "type": "shell",
      "command": "npm test",
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "test", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "core: test (watch)",
      "type": "shell",
      "command": "node_modules\\.bin\\vitest --root packages/core",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "group": "test",
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "core: test (coverage)",
      "type": "shell",
      "command": "node_modules\\.bin\\vitest run --root packages/core --coverage",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },

    // ── Core: Type-check ─────────────────────────────────────────────────────
    {
      "label": "core: type-check",
      "type": "shell",
      "command": "npm run lint",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": ["$tsc"]
    },

    // ── Workspace: build / test all ──────────────────────────────────────────
    {
      "label": "workspace: build all",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
