{
  "version": "2.0.0",
  "tasks": [

    // ── Core: Build ──────────────────────────────────────────────────────────
    {
      "label": "core: build",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "core: build (watch)",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[\\d+:\\d+:\\d+ [AP]M\\] Starting compilation",
          "endsPattern":   "^\\[\\d+:\\d+:\\d+ [AP]M\\] Found 0 errors"
        }
      }
    },

    // ── Core: Demo ───────────────────────────────────────────────────────────
    {
      "label": "core: demo (dev server)",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^\\[vite\\]\\s+(.*error.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern":   "Local:\\s+http"
        }
      }
    },

    // ── AngularJS: Demo ──────────────────────────────────────────────────────
    {
      "label": "angularjs: demo (dev server)",
      "type": "shell",
      "command": "node_modules\\.bin\\vite --config packages/angularjs/vite.config.js",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^\\[vite\\]\\s+(.*error.*)$",
