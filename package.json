{
  "name": "ultimate-grid-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Ultimate Data Grid — monorepo root",
  "scripts": {
    "build": "rollup -c packages/core/rollup.config.js",
    "test":  "vitest run --root packages/core",
    "lint":  "tsc --noEmit -p packages/core/tsconfig.json",
    "dev":   "vite --config packages/core/vite.config.ts",
    "dev:angularjs": "vite --config packages/angularjs/vite.config.js",
    "dev:react": "vite --config packages/react/vite.config.ts"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^24.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rollup": "^4.17.2",
    "rollup-plugin-dts": "^6.1.1",
    "tslib": "^2.6.2",
    "typescript": "^5.4.5",
    "vite": "^5.3.0",
    "vitest": "^1.6.0"
  },
  "license": "MIT"
}
