{
  "name": "ultimate-grid-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Ultimate Data Grid — monorepo root",
  "scripts": {
    "build": "rollup -c packages/core/rollup.config.js",
    "test":  "vitest run --root packages/core",
    "lint":  "tsc --noEmit -p packages/core/tsconfig.json",
    "dev":         "vite --config packages/core/vite.config.ts",
    "dev:angularjs":"vite --config packages/angularjs/vite.config.js",
    "dev:react":   "vite --config packages/react/vite.config.ts",
    "dev:vue":     "vite --config packages/vue/vite.config.ts",
    "dev:svelte":  "vite --config packages/svelte/vite.config.ts",
    "dev:angular": "vite --config packages/angular/vite.config.ts"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "@sveltejs/vite-plugin-svelte": "^3.1.0",
    "@angular/core": "^17.3.0",
    "@angular/common": "^17.3.0",
    "@angular/compiler": "^17.3.0",
    "@angular/platform-browser": "^17.3.0",
    "@angular/platform-browser-dynamic": "^17.3.0",
    "jsdom": "^24.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rollup": "^4.17.2",
    "rollup-plugin-dts": "^6.1.1",
    "rollup-plugin-vue": "^6.0.0",
    "rollup-plugin-svelte": "^7.2.0",
    "svelte-preprocess": "^6.0.0",
    "svelte": "^4.2.18",
    "vue": "^3.4.27",
    "tslib": "^2.6.2",
    "typescript": "^5.4.5",
    "vite": "^5.3.0",
    "vitest": "^1.6.0",
    "zone.js": "^0.14.0"
  },
  "license": "MIT"
}
