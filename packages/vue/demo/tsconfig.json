{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "jsx": "preserve"
  },
  "include": ["./**/*.ts", "./**/*.vue", "../src/**/*.vue", "../src/**/*.ts", "../../core/src/**/*.ts"]
}
