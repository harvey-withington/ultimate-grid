{
  "name": "@ultimate-grid/vue",
  "version": "0.1.0",
  "description": "Ultimate Data Grid — Vue 3 wrapper",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "demo":  "vite --config vite.config.ts",
    "dev":   "vite --config vite.config.ts",
    "lint":  "tsc --noEmit"
  },
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "devDependencies": {
    "vue": "^3.4.27"
  },
  "license": "MIT"
}
