{
  "name": "@ultimate-grid/svelte",
  "version": "0.1.0",
  "description": "Ultimate Data Grid — Svelte wrapper",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "demo":  "vite --config vite.config.ts",
    "dev":   "vite --config vite.config.ts",
    "lint":  "tsc --noEmit"
  },
  "peerDependencies": {
    "svelte": ">=4.0.0"
  },
  "devDependencies": {
    "svelte": "^4.2.18"
  },
  "license": "MIT"
}
